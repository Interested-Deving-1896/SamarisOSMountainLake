[Unit]
Description=Samaris Kernel Bridge (Kernel A)
Documentation=https://samaris.tech/docs/kernel-a
After=network.target volt-kernel-b.service
Wants=volt-kernel-b.service

[Service]
Type=simple
WorkingDirectory=/opt/volt/kernel
Environment=SAMARIS_STATE_ROOT=/home/user/.volt
ExecStart=/usr/bin/node /opt/volt/kernel/server.js
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
